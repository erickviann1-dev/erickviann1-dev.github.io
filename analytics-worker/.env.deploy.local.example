# Copy this file to .env.deploy.local and fill the values.
# Never commit .env.deploy.local.

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Worker URL will become:
# https://<WORKER_NAME>.<your-cloudflare-subdomain>.workers.dev
WORKER_NAME=erick-site-analytics
D1_DATABASE_NAME=erick_site_analytics_d1

# Private dashboard token. Use a long password-like string.
ADMIN_TOKEN=

# true = dashboard stores/shows raw IP; false = hashed IP.
STORE_RAW_IP=true
