name = "erick-site-analytics"
main = "worker.js"
compatibility_date = "2026-06-01"

[[d1_databases]]
binding = "ANALYTICS_DB"
database_name = "erick_site_analytics_d1"
database_id = "REPLACE_WITH_D1_DATABASE_ID"

[vars]
STORE_RAW_IP = "true"

# Set ADMIN_TOKEN as a Worker secret, not in this file:
# wrangler secret put ADMIN_TOKEN
